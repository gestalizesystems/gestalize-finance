# Banco de dados (Postgres via Docker)
DATABASE_URL="postgresql://gestalize:gestalize@localhost:5432/gestalize_finance?schema=public"

# Asaas (gateway de pagamento) — modo mock até você colocar a chave real
# Para ativar o real: ASAAS_MODE=live e cole a API key do sandbox/produção
ASAAS_MODE="mock"                       # mock | sandbox | live
ASAAS_API_KEY="seu_token_aqui"                        # cole sua chave Asaas aqui
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"   # produção: https://api.asaas.com/api/v3

# Notificações (placeholders — plugamos depois)
# WhatsApp (Z-API / Twilio) e Email (Resend) entram numa próxima etapa
RESEND_API_KEY=""
WHATSAPP_PROVIDER=""

# Identidade do emissor (aparece nas cobranças)
COMPANY_NAME="Gestalize Systems"
