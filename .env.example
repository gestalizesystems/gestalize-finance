# Banco de dados
# Local (Docker): use a string abaixo. Em produção (Railway), o próprio Railway
# fornece a DATABASE_URL do Postgres — referencie a variável do serviço Postgres.
DATABASE_URL="postgresql://gestalize:gestalize@localhost:5432/gestalize_finance?schema=public"

# URL pública do sistema (usada nos links de compartilhamento/og).
# Local: http://localhost:3010 — Produção: https://financeiro.gestalizebots.com.br
NEXT_PUBLIC_SITE_URL="http://localhost:3010"

# Asaas (gateway de pagamento) — modo mock até você colocar a chave real
# Para ativar o real: ASAAS_MODE=live e cole a API key do sandbox/produção
ASAAS_MODE="mock"                       # mock | sandbox | live
ASAAS_API_KEY="seu_token_aqui"                        # cole sua chave Asaas aqui
# ATENÇÃO: sandbox usa /api/v3, mas PRODUÇÃO usa /v3 (sem o /api).
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"   # produção: https://api.asaas.com/v3

# E-mail (Resend) — cole a API key e o remetente para enviar cobranças por e-mail.
# RESEND_FROM: use um domínio verificado no Resend em produção,
# ex: "Gestalize Finance <cobranca@gestalizesystems.com.br>".
RESEND_API_KEY=""
RESEND_FROM=""

# WhatsApp (Evolution API, self-hosted no Railway).
# BASE_URL = URL pública da sua Evolution; INSTANCE = nome da instância criada;
# API_KEY = a apikey (AUTHENTICATION_API_KEY da Evolution).
EVOLUTION_BASE_URL=""
EVOLUTION_INSTANCE=""
EVOLUTION_API_KEY=""

# Identidade do emissor (aparece nas cobranças)
COMPANY_NAME="Gestalize Systems"

# ----- Autenticação (login) -----
AUTH_SECRET="gere_com_openssl_rand_hex_32"
AUTH_EMAIL="seu@email.com"
AUTH_PASSWORD="sua_senha_forte"
# 2FA (opcional): segredo base32 do app autenticador. Vazio = 2FA desligado.
AUTH_TOTP_SECRET=""

# ----- Cron e Webhook -----
# CRON_SECRET protege o endpoint /api/cron/billing (motor de cobrança diário).
CRON_SECRET="gere_com_openssl_rand_hex_24"
# Token opcional do webhook do Asaas (cadastre o mesmo no painel do Asaas).
ASAAS_WEBHOOK_TOKEN=""
